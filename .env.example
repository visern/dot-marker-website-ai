# Groq API key, used for chat generation.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the Groq model used for chat responses.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Gemini API key. REQUIRED, not optional: Groq has no embeddings API, so
# gemini-embedding-001 is used for all retrieval regardless of which
# provider generates the reply. Also doubles as the fallback chat provider
# if Groq generation is down (after its own retries).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the Gemini model used for the generation fallback.
# GEMINI_CHAT_MODEL=gemini-3.5-flash

# Optional but recommended: enables per-IP rate limiting on /api/chat.
# Add the "Upstash Redis" integration from the Vercel Marketplace (free tier)
# or a Vercel KV store — either populates a REST URL/token pair automatically
# under one of these two naming schemes. Without these set, rate limiting is
# skipped and the chat endpoint has no abuse protection.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Only needed to run `npm run eval` (see eval/langsmith-eval.js) — not used
# by the deployed site at all. Get a free key at https://smith.langchain.com/settings
# LANGSMITH_API_KEY=
# Point at a deployed URL instead of a local dev server to eval a real deployment.
# CHAT_ENDPOINT_URL=http://localhost:3000/api/chat
