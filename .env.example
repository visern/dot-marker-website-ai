# Groq API key, used for both chat generation and embeddings.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the Groq model used for chat responses.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Optional but recommended: fallback chat provider if Groq generation is
# down (after its own retries). Get a free key at https://aistudio.google.com/apikey
# Only covers generation, not embeddings — see README.
# GEMINI_API_KEY=
# GEMINI_CHAT_MODEL=gemini-3.5-flash

# Optional but recommended: enables per-IP rate limiting on /api/chat.
# Add the "Upstash Redis" integration from the Vercel Marketplace (free tier)
# or a Vercel KV store — either populates a REST URL/token pair automatically
# under one of these two naming schemes. Without these set, rate limiting is
# skipped and the chat endpoint has no abuse protection.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
