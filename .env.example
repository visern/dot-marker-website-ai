# Claude API key, used by api/chat.js to generate responses.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voyage AI API key, used for embeddings (ingestion + query time).
# Get one at https://dash.voyageai.com/
VOYAGE_API_KEY=

# Optional: override the Claude model used for chat responses.
# CLAUDE_MODEL=claude-haiku-4-5-20251001
